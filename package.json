{
  "name": "skillsauth",
  "version": "3.0.1",
  "description": "Install verified AI agent skills from the SkillsAuth marketplace",
  "type": "module",
  "bin": {
    "skillsauth": "./dist/index.js"
  },
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "prepublishOnly": "pnpm build",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "ai",
    "agents",
    "skills",
    "skillsauth",
    "claude",
    "cursor",
    "windsurf",
    "codex",
    "github-copilot",
    "cline",
    "roo",
    "amp",
    "gemini-cli",
    "opencode",
    "vercel-skills"
  ],
  "author": "SkillsAuth",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/beinghimansh/skillsauth"
  },
  "homepage": "https://skillsauth.com",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "vitest": "^2.0.0"
  }
}
